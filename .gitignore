# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
functions/node_modules/
dist
functions/lib/
dist-ssr
*.local

# Environment — never commit secrets
.env
.env.local
.env.*.local

# Firebase service account (used by seed scripts / admin SDK)
service-account.json
*service-account*.json

# Vite cache
.vite/

# Firebase emulator export (regenerated on emulators:export — don't commit)
emulator-data/

# Firebase CLI deploy cache (regenerated on every deploy)
.firebase/

# Capacitor — native projects ARE committed; only build artifacts and secrets ignored
# iOS platform not yet scaffolded — revisit when ios/ is added via `npx cap add ios`
ios/
android/.gradle/
android/.idea/
android/build/
android/app/build/
android/captures/
android/local.properties
android/app/release/
android/keystore.properties

# Signing keystores — NEVER commit
*.keystore
*.jks

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
CLAUDE.md

# Claude Code per-user settings
.claude/settings.local.json

# Design / spec PDFs — large render artifacts, regenerated from source
Documents/*.pdf

# Local document scratch dir
Documents/
scripts/inspectEvalUser.ts
scripts/listEmulatorUsers.ts

# Graphify — commit only the three shareable artifacts (graph.json,
# graph.html, GRAPH_REPORT.md). Everything else under graphify-out/ is
# local/regenerated and stays out of git: extraction caches (cache/),
# timestamped backups (YYYY-MM-DD/), internal state (.graphify_*), and the
# manifest.json + cost.json originally listed here (now covered by the
# wildcard). This auto-ignores new cache files created on every rebuild.
graphify-out/*
!graphify-out/graph.json
!graphify-out/graph.html
!graphify-out/GRAPH_REPORT.md
